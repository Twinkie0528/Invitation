# Server endpoint for RSVP POST (set in Vercel project settings).
RSVP_ENDPOINT=

# Cloudinary account — host the three reference videos + venue images.
NEXT_PUBLIC_CLOUDINARY_CLOUD=

# Optional analytics (Plausible / Umami / GA4).
NEXT_PUBLIC_ANALYTICS_ID=

# Used by `npm run guests` to build the CSV of invitation links.
# Set to your Vercel deployment URL, no trailing slash.
NEXT_PUBLIC_SITE_URL=
